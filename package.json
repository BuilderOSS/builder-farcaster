{
  "name": "builder-farcaster",
  "version": "2.0.5",
  "description": "Tools and automation solutions for Builder DAO on Farcaster, enhancing community efficiency and engagement.",
  "type": "module",
  "scripts": {
    "build": "pnpm build:cli",
    "build:cli": "pnpm generate:prisma && vite build",
    "build:vercel": "pnpm generate:prisma && node scripts/build-vercel.js",
    "predev": "pnpm lint && pnpm build",
    "dev": "pnpm dev:process && pnpm dev:consume",
    "dev:consume": "node dist/index.js queues consume -l 10",
    "dev:fid": "node scripts/find-fid.js",
    "dev:invites": "node dist/index.js process invites",
    "dev:process": "node dist/index.js process proposals",
    "dev:propdates": "node dist/index.js process propdates",
    "dev:tokengen": "node dist/index.js farcaster token",
    "generate:prisma": "pnpm prisma:generate",
    "lint": "eslint",
    "lint:imports": "node scripts/audit-runtime-imports.js",
    "prepare": "husky || :",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status",
    "pretest": "pnpm build",
    "test": "vitest run --passWithNoTests"
  },
  "resolutions": {
    "elliptic": ">=6.6.0"
  },
  "dependencies": {
    "@buildeross/constants": "0.3.0",
    "@buildeross/types": "0.3.0",
    "@buildeross/utils": "0.3.0",
    "@inquirer/prompts": "7.1.0",
    "@noble/ed25519": "2.3.0",
    "@prisma/client": "5.22.0",
    "canonicalize": "2.0.0",
    "commander": "12.1.0",
    "dotenv": "16.4.5",
    "graphql": "16.9.0",
    "graphql-request": "7.1.2",
    "luxon": "3.5.0",
    "multiformats": "13.3.3",
    "p-limit": "7.3.0",
    "pino": "9.5.0",
    "pino-pretty": "13.0.0",
    "prisma": "5.22.0",
    "qrcode-terminal": "0.12.0",
    "remeda": "2.17.3",
    "remove-markdown": "0.6.0",
    "type-fest": "4.27.0",
    "uuid": "11.0.3",
    "viem": "2.47.6",
    "wagmi": "2.18.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "9.15.0",
    "@types/crypto-js": "4.2.2",
    "@types/eslint__js": "8.42.3",
    "@types/luxon": "3.4.2",
    "@types/node": "22.9.1",
    "@types/qrcode-terminal": "0.12.2",
    "@types/uuid": "10.0.0",
    "@typescript-eslint/parser": "8.46.2",
    "eslint": "9.15.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-jsdoc": "50.5.0",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-regexp": "2.7.0",
    "eslint-plugin-unicorn": "56.0.1",
    "eslint-plugin-vitest": "0.5.4",
    "globals": "15.12.0",
    "husky": "9.1.7",
    "lint-staged": "15.2.10",
    "prettier": "3.3.3",
    "prettier-plugin-jsdoc": "1.3.0",
    "prettier-plugin-organize-imports": "4.1.0",
    "prettier-plugin-packagejson": "2.5.5",
    "prettier-plugin-prisma": "5.0.0",
    "prettier-plugin-toml": "2.0.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.2",
    "vite": "5.4.11",
    "vite-plugin-node-polyfills": "0.22.0",
    "vitest": "2.1.5"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  }
}
