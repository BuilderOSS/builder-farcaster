datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Cache {
  key       String   @id
  value     String
  timestamp DateTime
}

model Queue {
  taskId      String    @id
  data        String
  timestamp   DateTime
  status      String
  retries     Int       @default(0)
  maxRetries  Int       @default(3)
  availableAt DateTime  @default(now())
  lockedAt    DateTime?
  lockedBy    String?
  completedAt DateTime?
  lastError   String?
  updatedAt   DateTime  @updatedAt

  @@index([status, availableAt, timestamp])
}
